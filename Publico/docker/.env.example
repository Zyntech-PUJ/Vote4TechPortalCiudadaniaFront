# Archivo: docker/.env
# NUNCA subas este archivo a git (ya esta en .gitignore con *.env)
#
# Pega aqui el token que te da Cloudflare al crear el tunnel.
# Lo obtienes en: https://one.dash.cloudflare.com/
# Zero Trust -> Networks -> Tunnels -> (tu tunnel) -> Configure -> Install connector -> Docker
# El token es la parte despues de --token en el comando que te muestra Cloudflare.

TUNNEL_TOKEN=pega_tu_token_aqui
